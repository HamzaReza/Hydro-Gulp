# Production: set secrets via Firebase CLI (not in .env):
#   firebase functions:secrets:set OPENROUTER_API_KEY
#   firebase functions:secrets:set REVENUECAT_WEBHOOK_SECRET
#
# Local emulator: copy to .secret.local (never deployed, gitignored):
#   cp .env.example .secret.local
#   # then paste real values into .secret.local
#
# Do NOT put these keys in functions/.env — that conflicts with secrets: [...] on deploy.

OPENROUTER_API_KEY=your_openrouter_key_here
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret_here
