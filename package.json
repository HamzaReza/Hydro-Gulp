    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "testflight": "eas build --platform ios --profile preview",
    "archive": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile internal",
    "submit:android:prod": "eas submit --platform android --profile production",
    "apk": "eas build --platform android --profile preview",
    "aab": "eas build --platform android --profile production",
    "pre:ios": "node scripts/update.js preview ios",
    "prod:ios": "node scripts/update.js production ios",
    "pre:android": "node scripts/update.js preview android",
    "prod:android": "node scripts/update.js production android"
  },
  "dependencies": {
